<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity2">


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FAFAFA"
        >

        <RelativeLayout
            android:id="@+id/re"
            android:layout_width="match_parent"
            android:layout_height="250dp">

            <ImageView
                android:id="@+id/pd"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:background="#EFEAEA"
                app:srcCompat="@drawable/dd" />

            <TextView
                android:id="@+id/titleve"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_alignParentBottom="true"
                android:textSize="22dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_marginStart="10dp"
                android:gravity="fill"
                android:text="TextView" />


        </RelativeLayout>



        <ImageView
            android:id="@+id/back"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_margin="20dp"
            app:srcCompat="@drawable/back" />

        <LinearLayout
            android:id="@+id/l1"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_below="@id/re"
            android:layout_marginStart="10dp"

            android:orientation="horizontal"
            >


            <TextView
                android:id="@+id/priceve"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:textSize="32dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:gravity="fill"
                android:text="$1899.99" />
            <TextView
                android:id="@+id/dpriceve"
                android:layout_width="180dp"
                android:paddingTop="15dp"
                android:layout_height="match_parent"
                android:textSize="18dp"
                android:text="TextView" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:weightSum="2"
                >


                <TextView
                    android:id="@+id/ratingve"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="18dp"
                    android:gravity="end"
                    android:layout_marginEnd="10dp"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:text="TextView" />

                <TextView
                    android:id="@+id/stockve"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:gravity="end"
                    android:layout_marginEnd="10dp"
                    android:textSize="18dp"
                    android:text="TextView" />
            </LinearLayout>





        </LinearLayout>

        <TextView
            android:id="@+id/desve"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:textSize="20dp"
            android:textColor="#1F1E1E"
            android:layout_below="@+id/l1"
            android:text="TextView" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:weightSum="3"
            android:orientation="horizontal"
            android:layout_below="@id/desve">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/pdshape"
                android:gravity="center"
                android:layout_margin="15dp"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/truck"
                    android:tint="#645D5D"
                    />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#645D5D"
                    android:gravity="center"
                    android:textSize="12dp"
                    android:text="SHIPPING"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textSize="18dp"
                    android:text="Fast and Free"/>




            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/pdshape"
                android:gravity="center"
                android:layout_margin="15dp"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/shield"
                    android:tint="#645D5D"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#645D5D"
                    android:gravity="center"
                    android:textSize="12dp"
                    android:text="WARRANTY"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textSize="18dp"
                    android:text="1 Year"/>




            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="15dp"
                android:background="@drawable/pdshape"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/restock"
                    android:tint="#645D5D"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#645D5D"
                    android:textSize="12dp"
                    android:gravity="center"
                    android:text="RETURNS"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:textSize="18dp"
                    android:gravity="center"
                    android:text="30 Days"/>




            </LinearLayout>







        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_alignParentBottom="true"
            android:layout_margin="15dp"
            android:background="@drawable/cartshap"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/cart"
                android:layout_marginEnd="15dp"
                android:tint="@color/white"/>

            <TextView
                android:id="@+id/pppp"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:textStyle="bold"
                android:textSize="20dp"
                android:textColor="@color/white"
                android:text="3454"/>


        </LinearLayout>


    </RelativeLayout>


</RelativeLayout>